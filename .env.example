# ------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored — never commit real secrets.
# ------------------------------------------------------------------

# Clerk — https://dashboard.clerk.com
# Create an application, then copy the keys from "API Keys".
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# Clerk Frontend API URL — found under "API Keys" → "Show JWT template"
# or "Domains" in the Clerk dashboard (e.g. https://your-app.clerk.accounts.dev)
CLERK_FRONTEND_API_URL=https://your-subdomain.clerk.accounts.dev

# Convex — https://dashboard.convex.dev
# Auto-populated by `npx convex dev` the first time you run it.
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-name.convex.cloud
